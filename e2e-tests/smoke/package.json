    "@mastra/libsql": "alpha",
    "@mastra/mcp": "alpha",
    "@mastra/memory": "alpha",
    "@mastra/observability": "alpha"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "execa": "^9.6.1",
    "get-port": "^7.1.0",
    "mastra": "alpha",
    "typescript": "^5.8.0",
    "vitest": "^4.1.0",
    "zod": "^4.3.6"
  }
}
