{
  "name": "e2e-smoke-tests",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npx mastra build",
    "build:studio": "npx mastra build --studio",
    "test": "vitest run --reporter=verbose",
