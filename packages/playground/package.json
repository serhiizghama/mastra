{
  "name": "@internal/playground",
  "private": true,
  "version": "1.3.15-alpha.3",
  "type": "module",
  "homepage": "https://mastra.ai",
  "files": [
    "dist",
    "CHANGELOG.md",
    "./**/*.d.ts"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mastra-ai/mastra.git",
    "directory": "packages/playground"
  },
  "bugs": {
    "url": "https://github.com/mastra-ai/mastra/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:watch": "vite build --watch",
    "lint": "eslint --no-warn-ignored .",
    "preview": "vite preview",
    "test:e2e": "pnpm test:e2e:setup && playwright test -c e2e/playwright.config.ts",
    "test:e2e:ui": "pnpm test:e2e:setup && playwright test -c e2e/playwright.config.ts --ui",
    "test:e2e:dev:ui": "pnpm test:e2e:setup && E2E_PORT=5173 playwright test -c e2e/playwright.config.ts --ui",
    "test:e2e:setup": "node ./e2e/scripts/info.js && pnpm install --ignore-workspace --dir ./e2e/kitchen-sink && playwright install chromium"
  },
  "dependencies": {
    "@lukeed/uuid": "^2.0.1",
    "@mastra/client-js": "workspace:*",
    "@mastra/core": "workspace:*",
    "@mastra/playground-ui": "workspace:^",
    "@mastra/react": "workspace:*",
    "@posthog/react": "^1.8.2",
    "@tanstack/react-query": "^5.90.21",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.522.0",
    "posthog-js": "^1.360.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.1"
  },
  "devDependencies": {
    "@internal/lint": "workspace:*",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/container-queries": "^0.1.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.27",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "nanoid": "^5.1.7",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "catalog:",
    "vite": "^7.3.1"
  }
}
